# ChitraFrame — environment variables
# Copy to `.env` for local dev; set the same keys as Cloudflare Pages
# env vars for production (Settings → Environment variables).
# Anything NOT prefixed VITE_ is server-only and never shipped to the browser.

# ── Supabase (YOUR project — not Lovable's) ─────────────────────────────────
# Publishable = client-side. Service role = server-only (BYPASSES RLS).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
VITE_SUPABASE_PROJECT_ID=YOUR-PROJECT
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# ── Razorpay ────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx           # set the same value in Razorpay dashboard webhook
VITE_RAZORPAY_KEY_ID=rzp_live_xxx     # public key_id, safe on client for checkout modal

# ── Cloudinary (product + review images) ────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxx
CLOUDINARY_API_KEY=xxx
CLOUDINARY_API_SECRET=xxx
CLOUDINARY_UPLOAD_FOLDER=photoframe
VITE_CLOUDINARY_CLOUD_NAME=xxx        # for building delivery URLs on the client

# ── Shiprocket ──────────────────────────────────────────────────────────────
# Shiprocket auth is email + password (no static API key). App logs in on
# demand and caches the JWT for ~23 hours.
SHIPROCKET_EMAIL=you@example.com
SHIPROCKET_PASSWORD=xxx
SHIPROCKET_PICKUP_LOCATION=Primary    # exact nickname from your Shiprocket pickup addresses
PICKUP_PINCODE=501504                 # origin pincode used for serviceability lookups

# ── Email — Brevo primary, Resend fallback ──────────────────────────────────
# MailerSend is used specifically for auth/magic-link emails (best deliverability
# for one-off transactional). Brevo + Resend handle order/marketing emails.
MAILERSEND_API_KEY=mlsn.xxx
BREVO_API_KEY=xkeysib-xxx
RESEND_API_KEY=re_xxx
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=ChitraFrame
OWNER_ALERT_EMAIL=you@example.com     # where new-order / low-stock alerts go

# ── Site / misc ─────────────────────────────────────────────────────────────
SITE_URL=https://yourdomain.com
SITE_NAME=ChitraFrame
WHATSAPP_NUMBER=91XXXXXXXXXX
FREE_SHIPPING_THRESHOLD=999           # fallback if site_settings_config row missing

# ── Optional: AI business-analyst chat in admin ─────────────────────────────
# Bring your own OpenAI / OpenRouter / Anthropic key. Server-side only.
AI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── Backup workflow (GitHub Actions only — do NOT put in Cloudflare) ────────
# These go in your GitHub repo → Settings → Secrets and variables → Actions.
# SUPABASE_DB_URL=postgresql://postgres:PWD@db.YOUR-PROJECT.supabase.co:5432/postgres
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=photoframe-backups
